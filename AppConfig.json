{
	"handler_timeout":{
		"/account.Status/Ping":{
			"GET":"200ms",
			"CRPC":"200ms",
			"GRPC":"200ms"
		}
	},
	"web_path_rewrite":{
		"GET":{
			"/origin/url":"/account.exampleservice/examplemethod"
		}
	},
	"handler_rate":{
		"/account.exampleservice/examplemethod":[{
			"methods":["GET","GRPC","CRPC"],
			"max_rate":10,
			"period":1,
			"rate_type":"path"
		},{
			"methods":["GET","GRPC","CRPC"],
			"max_rate":10,
			"period":1,
			"rate_type":"token"
		}]
	},
	"accesses":{
		"/account.exampleservice/examplemethod":[{
			"methods":["GET"],
			"accesses":["accesskey1","accesskey2"]
		},{
			"methods":["CRPC","GRPC"],
			"accesses":["accesskey3","accesskey4"]
		}],
		"/account.Base/BaseInfo":[{
			"methods":["CRPC","GRPC"],
			"accesses":["accesskey_base_info"]
		}],
		"/account.Base/Ban":[{
			"methods":["CRPC","GRPC"],
			"accesses":["accesskey_ban"]
		}],
		"/account.Base/Unban":[{
			"methods":["CRPC","GRPC"],
			"accesses":["accesskey_unban"]
		}]
	},
	"token_secret":"test",
	"service":{
		"token_expire":"24h",
		"support_email_service":["@163.com","@126.com","@sina.com","@sohu.com","@qq.com","@yahoo.com","@gmail.com","@outlook.com"],

		"wechat_oauth2":"",
		"wechat_app_id":"",
		"wechat_app_secret":""
	}
}
